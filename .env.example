# Ravo environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_REDIRECT_DOMAIN=go.ravo.fm
NODE_ENV=development

# --- Supabase (EU region) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=         # server only, never exposed to client
SUPABASE_JWT_SECRET=
SUPABASE_DB_URL=                   # for migrations / direct connection

# --- Internal secrets ---
INTERNAL_INGEST_HMAC_SECRET=       # signs click-ingest requests from edge → app
SESSION_COOKIE_SECRET=             # signs the active-org cookie
PGSODIUM_KEY=                      # for credential encryption at rest

# --- Upstash Redis (EU) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Inngest ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Resend ---
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=             # for delivery/bounce/complaint webhooks
RESEND_FROM_DEFAULT=Ravo <noreply@ravo.fm>

# --- Mollie ---
MOLLIE_API_KEY=                    # test_ for dev, live_ for prod
MOLLIE_WEBHOOK_SECRET=

# --- Sentry ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=                 # for source map uploads
NEXT_PUBLIC_SENTRY_DSN=

# --- BetterStack ---
BETTERSTACK_API_KEY=

# --- PostHog (EU Cloud) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Provider integrations ---
# Per-org credentials live in DB encrypted. Below are platform-level OAuth app credentials.
WEEZTIX_API_BASE_URL=https://api.weeztix.com
WEEZTIX_OAUTH_CLIENT_ID=           # from apiteam@weeztix.com
WEEZTIX_OAUTH_CLIENT_SECRET=
WEEZTIX_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/weeztix/callback

# Phase 0 smoke test only (scripts/weeztix-smoke.ts)
WEEZTIX_SMOKE_SHOP_ID=             # GUID of a test shop in the connected account
WEEZTIX_SMOKE_WEBHOOK_URL=         # tunnel URL → localhost:3030, e.g. https://xxx.ngrok.io/_smoke/webhook

# --- Auth ---
# Magic link configuration handled in Supabase Auth dashboard.
GOOGLE_OAUTH_CLIENT_ID=            # for ambassador social login
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Push notifications (Phase 9) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@ravo.fm
